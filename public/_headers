# Cloudflare Pages — Cache Headers

# HTML: nunca cachear (siempre pedir al servidor)
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Assets con hash en el nombre (Vite los genera con hash): caché larga
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# _redirects y _headers: nunca cachear
/_redirects
  Cache-Control: no-cache
/_headers
  Cache-Control: no-cache
