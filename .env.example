# Copia este archivo a .env y rellena con los valores de tu proyecto.
# Supabase Dashboard → Project Settings → API
#
# NOTA: estas dos variables son PÚBLICAS por diseño — viajan en el bundle
# del navegador. La protección real de los datos es RLS, no ocultar la key.
# NUNCA pongas aquí (ni en ningún VITE_*) la service_role key ni secretos
# de terceros (Brevo, etc.): esos van en Edge Functions / secrets de Supabase.

VITE_SUPABASE_URL=https://TU-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXX
